{
  "version": 2,
  "builds": [
    {
      "src": "ksb-fe/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/ksb-fe/browser"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
